{
  "name": "fund-helper",
  "displayName": "基金助手",
  "description": "在 VSCode 侧边栏查看自选基金实时估值、涨跌幅与收益",
  "version": "0.1.8",
  "author": "CrispyChicken",
  "publisher": "CrispyChicken",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crispyChicken999/fund-helper-vscode"
  },
  "homepage": "https://github.com/crispyChicken999/fund-helper-vscode#readme",
  "bugs": {
    "url": "https://github.com/crispyChicken999/fund-helper-vscode/issues"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "fund",
    "finance",
    "investment",
    "基金",
    "基金助手",
    "韭菜",
    "助手",
    "理财",
    "股票",
    "估值",
    "收益",
    "涨跌",
    "估算",
    "持仓",
    "helper",
    "fund helper"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fund-helper",
          "title": "基金助手",
          "icon": "resources/fund-icon.svg"
        }
      ]
    },
    "views": {
      "fund-helper": [
        {
          "id": "fundList",
          "icon": "resources/fund-icon.svg",
          "name": "基金列表"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "fundList",
        "contents": "欢迎使用基金助手！📈\n\n添加基金后即可查看实时估值与收益。\n\n[$(add) 添加基金](command:fund-helper.addFund)\n[$(cloud-download) 导入基金列表](command:fund-helper.importFund)\n[$(settings-gear) AI配置](command:fund-helper.configureAI)\n[$(lightbulb) AI分析](command:fund-helper.analyzeFunds)\n\n在设置（Ctrl+,）中搜索 「基金助手」 修改更多配置。"
      }
    ],
    "commands": [
      {
        "command": "fund-helper.addFund",
        "title": "添加基金",
        "icon": "$(add)"
      },
      {
        "command": "fund-helper.deleteFund",
        "title": "删除基金",
        "icon": "$(trash)"
      },
      {
        "command": "fund-helper.refreshFund",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "fund-helper.exportFund",
        "title": "导出基金列表"
      },
      {
        "command": "fund-helper.importFund",
        "title": "导入基金列表"
      },
      {
        "command": "fund-helper.configureAI",
        "title": "配置AI",
        "icon": "$(settings-gear)"
      },
      {
        "command": "fund-helper.analyzeFunds",
        "title": "AI分析",
        "icon": "$(sparkle)"
      },
      {
        "command": "fund-helper.addPosition",
        "title": "加仓",
        "icon": "$(plus)"
      },
      {
        "command": "fund-helper.reducePosition",
        "title": "减仓",
        "icon": "$(dash)"
      },
      {
        "command": "fund-helper.editPosition",
        "title": "修改持仓",
        "icon": "$(edit)"
      },
      {
        "command": "fund-helper.sortByDefault",
        "title": "默认排序",
        "icon": "$(list-unordered)"
      },
      {
        "command": "fund-helper.sortByChangePercent",
        "title": "涨跌幅",
        "icon": "$(graph-line)"
      },
      {
        "command": "fund-helper.sortByDailyGain",
        "title": "估算收益",
        "icon": "$(pulse)"
      },
      {
        "command": "fund-helper.sortByHoldingAmount",
        "title": "持有额",
        "icon": "$(credit-card)"
      },
      {
        "command": "fund-helper.sortByHoldingGain",
        "title": "持有收益",
        "icon": "$(diff)"
      },
      {
        "command": "fund-helper.sortByHoldingGainRate",
        "title": "收益率",
        "icon": "$(symbol-numeric)"
      },
      {
        "command": "fund-helper.toggleStatusBarHide",
        "title": "切换状态栏隐藏/显示状态",
        "icon": "$(eye)"
      },
      {
        "command": "fund-helper.copyFundDetail",
        "title": "复制",
        "icon": "$(copy)"
      },
      {
        "command": "fund-helper.copyFundCode",
        "title": "复制代码"
      },
      {
        "command": "fund-helper.viewFundDetail",
        "title": "查看详情",
        "icon": "$(graph-line)"
      },
      {
        "command": "fund-helper.openMarket",
        "title": "行情中心",
        "icon": "$(graph)"
      },
      {
        "command": "fund-helper.filterFunds",
        "title": "筛选基金",
        "icon": "$(search)"
      },
      {
        "command": "fund-helper.clearFilter",
        "title": "清除筛选",
        "icon": "$(clear-all)"
      },
      {
        "command": "fund-helper.setRefreshInterval",
        "title": "修改自动刷新间隔"
      },
      {
        "command": "fund-helper.toggleAutoRefresh",
        "title": "开启/关闭自动刷新"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "fund-helper.refreshFund",
          "when": "view == fundList",
          "group": "navigation@1"
        },
        {
          "command": "fund-helper.addFund",
          "when": "view == fundList",
          "group": "navigation@2"
        },
        {
          "command": "fund-helper.importFund",
          "when": "view == fundList"
        },
        {
          "command": "fund-helper.exportFund",
          "when": "view == fundList"
        },
        {
          "command": "fund-helper.configureAI",
          "when": "view == fundList"
        },
        {
          "command": "fund-helper.analyzeFunds",
          "when": "view == fundList",
          "group": "navigation@3"
        },
        {
          "command": "fund-helper.toggleStatusBarHide",
          "when": "view == fundList"
        },
        {
          "command": "fund-helper.setRefreshInterval",
          "when": "view == fundList"
        },
        {
          "command": "fund-helper.toggleAutoRefresh",
          "when": "view == fundList"
        }
      ],
      "view/item/context": [
        {
          "command": "fund-helper.addPosition",
          "when": "view == fundList && viewItem == fundItem",
          "group": "inline@1"
        },
        {
          "command": "fund-helper.reducePosition",
          "when": "view == fundList && viewItem == fundItem",
          "group": "inline@2"
        },
        {
          "command": "fund-helper.editPosition",
          "when": "view == fundList && viewItem == fundItem",
          "group": "inline@3"
        },
        {
          "command": "fund-helper.deleteFund",
          "when": "view == fundList && viewItem == fundItem",
          "group": "inline@4"
        },
        {
          "command": "fund-helper.viewFundDetail",
          "when": "view == fundList && viewItem == fundItem",
          "group": "inline@5"
        },
        {
          "command": "fund-helper.sortByDefault",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@1"
        },
        {
          "command": "fund-helper.sortByChangePercent",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@2"
        },
        {
          "command": "fund-helper.sortByDailyGain",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@3"
        },
        {
          "command": "fund-helper.sortByHoldingAmount",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@4"
        },
        {
          "command": "fund-helper.sortByHoldingGain",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@5"
        },
        {
          "command": "fund-helper.sortByHoldingGainRate",
          "when": "view == fundList && viewItem == sortItem",
          "group": "inline@6"
        },
        {
          "command": "fund-helper.copyFundDetail",
          "when": "view == fundList && viewItem == detailItem",
          "group": "inline"
        },
        {
          "command": "fund-helper.openMarket",
          "when": "view == fundList && viewItem == marketFolderItem",
          "group": "inline@1"
        },
        {
          "command": "fund-helper.filterFunds",
          "when": "view == fundList && viewItem =~ /filterItem/",
          "group": "inline@1"
        },
        {
          "command": "fund-helper.clearFilter",
          "when": "view == fundList && viewItem == filterItem_active",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "基金助手",
      "properties": {
        "fund-helper.funds": {
          "type": "array",
          "default": [],
          "description": "自选基金列表（格式：{code, cost, num}），数据保存在用户全局配置中",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "num": {
                "type": "string",
                "default": "0"
              },
              "cost": {
                "type": "string",
                "default": "0"
              }
            }
          }
        },
        "fund-helper.refreshInterval": {
          "type": "number",
          "default": 30,
          "description": "数据刷新间隔（秒），仅交易时间内生效",
          "minimum": 5
        },
        "fund-helper.sortMethod": {
          "type": "string",
          "default": "default",
          "description": "基金列表排序方式",
          "enum": [
            "default",
            "changePercent_desc",
            "changePercent_asc",
            "dailyGain_desc",
            "dailyGain_asc",
            "holdingAmount_desc",
            "holdingAmount_asc",
            "holdingGain_desc",
            "holdingGain_asc",
            "holdingGainRate_desc",
            "holdingGainRate_asc"
          ],
          "enumDescriptions": [
            "默认排序（添加顺序）",
            "涨跌幅 ↓（从高到低）",
            "涨跌幅 ↑（从低到高）",
            "估算收益 ↓（从高到低）",
            "估算收益 ↑（从低到高）",
            "持有额 ↓（从高到低）",
            "持有额 ↑（从低到高）",
            "持有收益 ↓（从高到低）",
            "持有收益 ↑（从低到高）",
            "持有收益率 ↓（从高到低）",
            "持有收益率 ↑（从低到高）"
          ]
        },
        "fund-helper.hideStatusBar": {
          "type": "boolean",
          "default": false,
          "description": "是否隐藏状态栏金额（开启后状态栏只显示图标内容，鼠标悬停时可查看具体金额）",
          "markdownDescription": "开启可暂时隐藏收益数字，鼠标悬停时可展示详情"
        },
        "fund-helper.aiProvider": {
          "type": "string",
          "default": "openai",
          "description": "AI服务提供商",
          "enum": [
            "openai",
            "aliyun",
            "siliconflow",
            "deepseek"
          ],
          "enumDescriptions": [
            "OpenAI官方API",
            "阿里云百炼",
            "硅基流动",
            "DeepSeek"
          ]
        },
        "fund-helper.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "AI API密钥",
          "markdownDescription": "AI服务的API密钥。**请注意保护您的密钥安全**"
        },
        "fund-helper.aiApiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "AI API端点地址",
          "markdownDescription": "AI服务的API端点URL"
        },
        "fund-helper.aiModel": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "description": "AI模型名称",
          "markdownDescription": "使用的AI模型名称"
        },
        "fund-helper.enableAIAnalysis": {
          "type": "boolean",
          "default": false,
          "description": "启用AI分析功能",
          "markdownDescription": "是否启用AI基金分析功能"
        },
        "fund-helper.aiTemperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "AI分析温度参数",
          "markdownDescription": "控制AI输出的随机性，0-2之间，数值越高越随机"
        },
        "fund-helper.aiMaxTokens": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "maximum": 4000,
          "description": "AI最大输出token数",
          "markdownDescription": "限制AI分析结果的最大长度"
        },
        "fund-helper.savedAIConfigs": {
          "type": "array",
          "default": [],
          "description": "保存的AI配置列表",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "temperature": {
                "type": "number"
              },
              "maxTokens": {
                "type": "number"
              },
              "isDefault": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "openai": "^6.25.0"
  }
}
